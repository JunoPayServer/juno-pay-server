# juno-pay-server
JUNO_PAY_ADMIN_PASSWORD=change_me
JUNO_PAY_TOKEN_KEY_HEX=replace_me_32_bytes_hex

# Storage (optional; defaults to embedded SQLite)
# JUNO_PAY_STORE_DRIVER=sqlite|postgres|mysql|mongo
# JUNO_PAY_STORE_DSN= # required for postgres/mysql/mongo
# JUNO_PAY_STORE_DB=  # required for mongo
# JUNO_PAY_STORE_PREFIX= # optional table/collection prefix

# docker-compose convenience
JUNO_CHAIN=regtest
JUNO_SCAN_UA_HRP=jregtest

# optional overrides
# JUNO_PAY_PORT_HOST=18082
# JUNO_RPC_PORT_HOST=28232
# JUNO_SCAN_PORT_HOST=18080
# JUNOCASH_VERSION=0.9.7
# JUNO_SCAN_REPO=https://github.com/Abdullah1738/juno-scan.git
# JUNO_SCAN_REF=main

# demo app (optional)
# JUNO_DEMO_PORT_HOST=18083
# JUNO_PAY_DEMO_MERCHANT_API_KEY=replace_me
