aws_region  = "us-east-1"
name_prefix = "juno-pay"

vpc_id    = "vpc-xxxxxxxx"
subnet_id = "subnet-xxxxxxxx"

allowed_cidrs = ["0.0.0.0/0"]

admin_password_ssm_param = "/juno-pay/admin_password"
token_key_ssm_param      = "/juno-pay/token_key_hex"

image_juno_pay_server = "123456789012.dkr.ecr.us-east-1.amazonaws.com/juno-pay-juno-pay-server:TAG"
image_junocashd       = "123456789012.dkr.ecr.us-east-1.amazonaws.com/juno-pay-junocashd:TAG"
image_juno_scan       = "123456789012.dkr.ecr.us-east-1.amazonaws.com/juno-pay-juno-scan:TAG"

juno_chain = "mainnet"

# Optional: RDS Postgres for juno-scan.
enable_rds_postgres = false
rds_subnet_ids      = ["subnet-aaaaaaaa", "subnet-bbbbbbbb"]

# Optional: MSK Kafka cluster for outbound events.
enable_msk    = false
msk_subnet_ids = ["subnet-aaaaaaaa", "subnet-bbbbbbbb"]

